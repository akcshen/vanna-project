# DeepSeek / OpenAI 兼容模型 API（必填）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# 模型 API 地址（支持自定义代理或私有部署）
# 官方 DeepSeek: https://api.deepseek.com 或 https://api.deepseek.com/v1
# 自建/代理示例: https://your-proxy.example.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 服务配置
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
AI_LOG_ENABLED=true
# 开发热重载（长请求时可能导致 curl Empty reply，生产环境保持 false）
RELOAD=false

# 业务数据库（MySQL）
DB_TYPE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=your_database

# 训练使用的业务表
MYSQL_TABLES=vd_daily

# ChromaDB 向量库存储路径
CHROMA_PATH=./data/chroma

# 时间过滤字段（用于 dataPeriod / baselinePeriod）
DATE_COLUMN=stat_time

# PPT 模板存储（SQLite，独立于业务 MySQL）
PPT_TEMPLATE_DB_PATH=./data/ppt_templates.db
