# DeepSeek / OpenAI 兼容模型 API（必填）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# 模型 API 地址（支持自定义代理或私有部署）
# 官方 DeepSeek: https://api.deepseek.com 或 https://api.deepseek.com/v1
# 自建/代理示例: https://your-proxy.example.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 服务配置
HOST=0.0.0.0
PORT=8080

# 数据库类型: sqlite / mysql
DB_TYPE=mysql

# MySQL 连接（DB_TYPE=mysql 时必填）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=your_database

# 可选：只训练指定表，逗号分隔，例如 sales,products
# MYSQL_TABLES=sales,products

# SQLite 连接（DB_TYPE=sqlite 时使用）
DATABASE_PATH=./data/sales.db

# ChromaDB 向量库存储路径
CHROMA_PATH=./data/chroma
